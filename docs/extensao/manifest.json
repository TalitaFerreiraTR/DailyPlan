{
  "manifest_version": 3,
  "name": "DailyPlan | Product Focus",
  "version": "7.0.0",
  "description": "Gestão diária de produto com integração SGD — PSAI, SS e SAI",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://*.dominiosistemas.com.br/*",
    "http://*.dominiosistemas.com.br/*",
    "https://talitaferreiratr.github.io/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" },
  "content_scripts": [
    {
      "matches": ["https://sgd.dominiosistemas.com.br/sgsa/faces/psai.html*"],
      "js": ["content-psai-scraper.js", "injetor-psai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sgd.dominiosistemas.com.br/sgsa/faces/ss.html*"],
      "js": ["content-ss-scraper.js","injector-ss.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sgsai.dominiosistemas.com.br/sgsai/faces/sai.html*"],
      "js": ["injector-sai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://talitaferreiratr.github.io/DailyPlan/*"],
      "js": ["sync-to-web.js"],
      "run_at": "document_idle"
    }
  ]
}
